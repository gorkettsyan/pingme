# Required: Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Optional: SQLite database path (default: sqlite+aiosqlite:///reminder_app.db)
# DATABASE_URL=sqlite+aiosqlite:///reminder_app.db

# Optional: Timezone (default: UTC)
# TIMEZONE=America/New_York

# Optional: Ollama LLM (for AI shames + natural language reminders)
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:1.5b

# Optional: WhatsApp via Twilio (configure via /channels command in the bot)
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_FROM_PHONE=+1234567890
